<div class="cart-container">

    <h1 class="display-4 fw-bold text-dark mb-5 text-center">
        <i class="bi bi-cart3"></i> Mi Carrito
    </h1>

    {{#if cart.products.length}}

    <div class="row g-4">

        <!-- ===================== LISTA DE PRODUCTOS ===================== -->
        <div class="col-lg-8">

            {{#each cart.products}}

            <div class="card cart-card shadow-sm border-0 rounded-4 mb-3" data-pid="{{this.product._id}}" data-price="{{this.product.price}}">

                <div class="card-body">

                    <div class="row align-items-center g-3">

                        <div class="col-3 col-md-2">
                            <img
                                src="{{this.product.thumbnails.[0]}}"
                                alt="{{this.product.title}}"
                                class="img-fluid rounded-3 product-img"
                                style="height: 90px; object-fit: cover; width: 100%;"
                            >
                        </div>

                        <div class="col-9 col-md-4">
                            <h5 class="fw-bold mb-1">{{this.product.title}}</h5>
                            <span class="text-muted small">${{this.product.price}} c/u</span>
                        </div>

                        <div class="col-6 col-md-3">
                            <div class="d-flex align-items-center gap-2">
                                <button class="btn btn-sm btn-outline-dark rounded-circle qty-btn" data-action="decrease" data-pid="{{this.product._id}}">-</button>
                                <span class="fw-bold qty-value">{{this.quantity}}</span>
                                <button class="btn btn-sm btn-outline-dark rounded-circle qty-btn" data-action="increase" data-pid="{{this.product._id}}">+</button>
                            </div>
                        </div>

                        <div class="col-4 col-md-2 text-md-end">
                            <span class="fw-bold text-success fs-5 subtotal-value">
                                ${{this.product.price}}
                            </span>
                        </div>

                        <div class="col-2 col-md-1 text-end">
                            <button class="btn btn-sm btn-outline-danger remove-btn" data-pid="{{this.product._id}}" title="Eliminar">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>

                    </div>

                </div>

            </div>

            {{/each}}

            <a href="/products" class="btn btn-outline-dark mt-2">
                <i class="bi bi-arrow-left"></i> Seguir Comprando
            </a>

        </div>

        <!-- ===================== RESUMEN Y CHECKOUT ===================== -->
        <div class="col-lg-4">

            <div class="card shadow border-0 rounded-4 sticky-top" style="top: 20px;">

                <div class="card-body p-4">

                    <h4 class="fw-bold mb-4">Resumen de compra</h4>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal</span>
                        <span id="cart-subtotal" class="fw-semibold">$0</span>
                    </div>

                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Envío</span>
                        <span class="fw-semibold text-success">Gratis</span>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold fs-5">Total</span>
                        <span id="cart-total" class="fw-bold fs-5 text-success">$0</span>
                    </div>

                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-credit-card"></i> Medios de pago
                    </h6>

                    <div class="list-group mb-4">

                        <label class="list-group-item d-flex align-items-center gap-2">
                            <input class="form-check-input mt-0" type="radio" name="metodoPago" value="Tarjeta de crédito/débito" checked>
                            <i class="bi bi-credit-card-2-front"></i> Tarjeta de crédito / débito
                        </label>

                        <label class="list-group-item d-flex align-items-center gap-2">
                            <input class="form-check-input mt-0" type="radio" name="metodoPago" value="Mercado Pago">
                            <i class="bi bi-wallet2"></i> Mercado Pago
                        </label>

                        <label class="list-group-item d-flex align-items-center gap-2">
                            <input class="form-check-input mt-0" type="radio" name="metodoPago" value="Efectivo">
                            <i class="bi bi-cash-coin"></i> Efectivo
                        </label>

                    </div>

                    <button id="checkout-btn" class="btn btn-success btn-lg w-100" data-cart-id="{{cart._id}}">
                        <i class="bi bi-bag-check-fill"></i> Comprar
                    </button>

                    <button id="clear-cart-btn" class="btn btn-outline-danger w-100 mt-2" data-cart-id="{{cart._id}}">
                        <i class="bi bi-trash"></i> Vaciar carrito
                    </button>

                </div>

            </div>

        </div>

    </div>

    {{else}}

    <div class="text-center py-5">

        <i class="bi bi-cart-x" style="font-size: 5rem; color: #ccc;"></i>

        <p class="fs-4 text-muted mt-3">Tu carrito está vacío.</p>

        <a href="/products" class="btn btn-success btn-lg mt-3">
            <i class="bi bi-shop"></i> Ir al catálogo
        </a>

    </div>

    {{/if}}

</div>

<script src="/js/cart.js"></script>