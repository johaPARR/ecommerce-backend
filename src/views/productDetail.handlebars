<div class="product-detail-container">

    <h2>{{product.title}}</h2>

    <div class="product-card">

        <img
            src="{{product.thumbnails.[0]}}"
            alt="{{product.title}}"
            class="product-img"
        >

        <p>
            <strong>Descripción:</strong>
            {{product.description}}
        </p>

        <p>
            <strong>Categoría:</strong>
            {{product.category}}
        </p>

        <p>
            <strong>Precio:</strong>
            ${{product.price}}
        </p>

        <p>
            <strong>Stock:</strong>
            {{product.stock}}
        </p>

        <button
            class="add-to-cart-btn"
            onclick="addToCart('{{product._id}}')"
        >
            Agregar al Carrito
        </button>

    </div>

    <br>

    <a href="/products">
        <button>
            ← Volver al Catálogo
        </button>
    </a>

</div>